# Laracolor Configuration
# Available palettes: pastel, vibrant, dark, light, muted, warm, cold, random
LARACOLOR_PALETTE=pastel

# Custom saturation range (0-100)
LARACOLOR_SATURATION_MIN=35
LARACOLOR_SATURATION_MAX=56

# Custom lightness range (0-100)
LARACOLOR_LIGHTNESS_MIN=78
LARACOLOR_LIGHTNESS_MAX=89

# Cache settings
LARACOLOR_CACHE_ENABLED=false
LARACOLOR_CACHE_TTL=3600